# LamMail Caddyfile — install at /etc/caddy/Caddyfile
# Webmail lives on one domain, mail addresses live on another.
#
#   - Webmail UI:  https://yunaalways.cyou
#   - API:         https://api.yunaalways.cyou
#   - Mail in:     vietkieu.edu.pl  MX 10 mail.vietkieu.edu.pl  (port 25)

{
        email admin@yunaalways.cyou
}

# ─── Webmail UI ─────────────────────────────────────────────────────────
yunaalways.cyou, www.yunaalways.cyou {
        root * /opt/lammail/app/apps/web/dist
        encode zstd gzip

        # Admin SPA — must come first. Without an explicit handle block the
        # bare try_files below would rewrite /admin to /index.html.
        @admin path /admin /admin/*
        handle @admin {
                try_files {path} /admin.html
                file_server
        }

        # Visitor SPA — everything else.
        handle {
                try_files {path} /index.html
                file_server
        }

        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains"
                X-Content-Type-Options nosniff
                X-Frame-Options DENY
                Referrer-Policy strict-origin-when-cross-origin
                Permissions-Policy "interest-cohort=()"
                Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.yunaalways.cyou; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
                -Server
        }
}

# ─── API ────────────────────────────────────────────────────────────────
api.yunaalways.cyou {
        encode zstd gzip

        handle /v1/* {
                reverse_proxy 127.0.0.1:3001 {
                        # Stream SSE without buffering on /v1/api/.../stream.
                        flush_interval -1
                }
        }

        handle {
                respond 404
        }

        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains"
                X-Content-Type-Options nosniff
                Referrer-Policy no-referrer
                -Server
        }
}
