# LamMail API configuration
# Copy to .env and adjust for your environment.

# --- Runtime ---
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# --- Provider mode ---
# local    = self-hosted SMTP + SQLite (production default)
# upstream = proxy to Mail.tm (escape hatch if port 25 is blocked)
PROVIDER=local

# --- Domain settings ---
# Domain mailboxes will use. Must match the MX target you configured.
MAIL_DOMAIN=vietkieu.edu.pl

# Comma-separated list of allowed mailbox domains.
# Useful if you later add subdomains.
ALLOWED_DOMAINS=vietkieu.edu.pl

# --- TTLs (seconds) ---
# How long a mailbox lives after creation. Messages inherit the parent TTL.
MAILBOX_TTL_SECONDS=3600

# How often the cleanup job runs.
CLEANUP_INTERVAL_SECONDS=60

# --- SMTP receiver ---
SMTP_ENABLED=true
SMTP_PORT=2525
SMTP_HOSTNAME=mail.vietkieu.edu.pl
SMTP_MAX_SIZE_BYTES=5242880

# --- Storage ---
DB_PATH=./data/mail.db

# --- CORS ---
# Comma-separated list of allowed origins for the API.
CORS_ORIGINS=http://localhost:5173,https://yunaalways.cyou,https://www.yunaalways.cyou

# --- Rate limits ---
RATE_LIMIT_MAX_PER_MINUTE=120
RATE_LIMIT_CREATE_PER_MINUTE=10
# Per-IP cap on /v1/unlock attempts. Keep low to discourage passcode brute force.
RATE_LIMIT_UNLOCK_PER_MINUTE=5

# --- Admin ---
# Bearer token for /v1/admin/* endpoints and the /admin web page.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Leave blank to disable admin endpoints entirely.
ADMIN_TOKEN=

# Session token TTL after a successful /v1/unlock (seconds). Default 7 days.
SESSION_TTL_SECONDS=604800
